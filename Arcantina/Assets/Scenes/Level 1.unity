--- !u!114 &320182105
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 320182103}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c78ab9e659e124e4aa13b20f5fcf0682, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  nameText: {fileID: 2117861748}
  speechText: {fileID: 976396126}
  characterPortrait: {fileID: 615353275}
  dialoguePanel: {fileID: 614153977}
  dialogueLines:
  - characterName: "Zs\xE1kos frod\xF3"
    portrait: {fileID: 21300000, guid: cb28ad361e09e0a4ebd40b1956aae94a, type: 3}
    text: "\xDAristen! Csupa v\xE9r vagy! Mi t\xF6rt\xE9nt? "
  - characterName: Derek
    portrait: {fileID: 21300000, guid: 8d8ea794c5e464a418547add38af5b82, type: 3}
    text: "Nora, a feles\xE9gem alm\xE1t k\xEDv\xE1nt az \xE9jszaka k\xF6zep\xE9n.
      Nem volt m\xE1s v\xE1laszt\xE1som, loptam a szomsz\xE9d f\xE1j\xE1r\xF3l, de
      leestem."
  - characterName: Igor
    portrait: {fileID: 21300000, guid: c9f7047e7f90e4a46b6479e59844c388, type: 3}
    text: "\xC9s mi\xE9rt nem m\xE9sz haza? "
  - characterName: Derek
    portrait: {fileID: 21300000, guid: c9f7047e7f90e4a46b6479e59844c388, type: 3}
    text: "Ki van z\xE1rva! Nora el\xE1jul a v\xE9r l\xE1tv\xE1ny\xE1t\xF3l, ha pedig
      megl\xE1tn\xE1 a k\xF6t\xE9seket rajtam, leszedn\xE9 a fejemet a vakmer\u0151s\xE9gem
      miatt. Kell egy gy\xF3gy\xEDt\xF3 f\u0151zet, de azonnal!"
  - characterName: Igor
    portrait: {fileID: 21300000, guid: c9f7047e7f90e4a46b6479e59844c388, type: 3}
    text: "Idd meg, \xE9s legk\xF6zelebb ink\xE1bb v\xE1rd meg a reggelt."
